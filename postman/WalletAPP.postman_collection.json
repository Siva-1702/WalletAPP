{
  "info": {
    "name": "WalletAPP API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Health",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api/v1/health"
      }
    },
    {
      "name": "Request OTP",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": { "mode": "raw", "raw": "{\n  \"mobileNumber\": \"+919876543210\",\n  \"purpose\": \"REGISTER\"\n}" },
        "url": "{{baseUrl}}/api/v1/auth/otp/request"
      }
    },
    {
      "name": "Verify OTP",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": { "mode": "raw", "raw": "{\n  \"mobileNumber\": \"+919876543210\",\n  \"purpose\": \"REGISTER\",\n  \"otp\": \"123456\",\n  \"fullName\": \"Praveen Kumar\"\n}" },
        "url": "{{baseUrl}}/api/v1/auth/otp/verify"
      }
    }
  ],
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000" }
  ]
}
